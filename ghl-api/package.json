{
  "name": "highlevel-pit",
  "version": "1.0.0",
  "description": "Use HighLevel SDK usign PIT token",
  "main": "src/server.ts",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "dev": "npm run build && node dist/server.js",
    "dev:ts": "ts-node -r tsconfig-paths/register src/server.ts",
    "dev:watch": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch"
  },
  "keywords": [
    "highlevel",
    "sdk",
    "pit"
  ],
  "author": "HighLevel",
  "license": "ISC",
  "dependencies": {
    "@gohighlevel/api-client": "^1.0.0",
    "@types/nodemailer": "^7.0.2",
    "@types/sqlite3": "^3.1.11",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.1.2",
    "cors": "^2.8.5",
    "crawl4ai": "^1.0.1",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "form-data": "^4.0.4",
    "lodash": "^4.17.21",
    "nodemailer": "^7.0.6",
    "puppeteer": "^24.18.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^4.5.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^2.0.22",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "vitest": "^2.0.0"
  }
}
