generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users table - minimal schema for authentication only
// All profile data (firstName, lastName, businessName, phone, etc.) comes from GoHighLevel
model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String
  role          String    @default("member")
  status        String    @default("pending")
  emailVerified Boolean   @default(false)
  ghlContactId  String?   @unique
  lastLoginAt   DateTime?
  passwordResetToken        String?
  passwordResetTokenExpiry  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  sessions Session[]
  votes    Vote[]
  jobs     Job[]

  @@index([email])
  @@index([ghlContactId])
  @@index([passwordResetToken])
  @@map("users")
}

// Sessions table for authentication tokens
model Session {
  id          Int      @id @default(autoincrement())
  userId      Int
  sessionId   String   @unique
  accessToken String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("sessions")
}

// Nominations table for Business of the Month and Customer Service Superstar awards
model Nomination {
  id           Int      @id @default(autoincrement())
  type         String   // 'business' or 'individual'
  category     String   // 'business_of_month' or 'customer_service_superstar'
  name         String?  // Individual's name (for customer service superstar)
  businessName String   // Business name
  reason       String   @db.Text
  status       String   @default("pending") // pending, approved, rejected
  isWinner     Boolean  @default(false) // Marked as winner by admin
  winnerMonth  String?  // Format: YYYY-MM (month for which this nomination won)
  winnerYear   String?  // Format: YYYY (year for which this nomination won - for yearly awards)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relations
  votes        Vote[]
  
  @@index([type, category])
  @@index([status])
  @@index([createdAt])
  @@index([isWinner])
  @@map("nominations")
}

// Votes table for board members to vote on nominations
model Vote {
  id              Int        @id @default(autoincrement())
  nominationId    Int
  userId          Int        // Board member who voted
  votingMonth     String     // Format: YYYY-MM (e.g., "2025-01" for voting in January for February winners)
  votingCategory  String     // 'business_of_month' or 'customer_service_superstar'
  voteType        String     @default("monthly") // 'monthly' or 'yearly'
  voteValue       Boolean    @default(true) // Simple yes/no vote (checkbox)
  comment         String?    @db.Text
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  // Relations
  nomination   Nomination @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, votingCategory, votingMonth, voteType]) // One vote per user per category per month per type
  @@index([nominationId])
  @@index([userId])
  @@index([votingMonth])
  @@index([voteType])
  @@map("votes")
}

// Job postings table - chamber members can post job opportunities
model Job {
  id                     Int              @id @default(autoincrement())
  title                  String
  company                String
  location               String
  type                   String           // full-time, part-time, contract, internship
  salary                 String?
  description            String           @db.Text
  requirements           String?          @db.Text // JSON array stored as text
  postedById             Int              // Member who posted the job
  expiresAt              DateTime?
  status                 String           @default("active") // active, closed, expired
  externalApplicationUrl String?          // Optional: redirect to external site for application
  viewCount              Int              @default(0) // Track how many times job has been viewed
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  
  // Relations
  postedBy               User             @relation(fields: [postedById], references: [id], onDelete: Cascade)
  applications           JobApplication[]
  
  @@index([postedById])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("jobs")
}

// Job applications table - anyone can apply for jobs
model JobApplication {
  id                     Int      @id @default(autoincrement())
  jobId                  Int
  applicantName          String
  applicantEmail         String
  applicantPhone         String?
  coverLetter            String?  @db.Text
  resumeFileUrl          String?  // URL to uploaded resume file
  resumeFileName         String?  // Original filename
  resumeGoogleDocLink    String?  // Optional Google Doc link
  status                 String   @default("pending") // pending, reviewed, shortlisted, rejected
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  
  // Relations
  job                    Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  @@index([jobId])
  @@index([applicantEmail])
  @@index([status])
  @@index([createdAt])
  @@map("job_applications")
}

// Member business categories - stores up to 3 subcategory selections per GHL contact
// Keyed by ghlContactId (not userId) because not all GHL contacts have portal accounts
model MemberCategory {
  id           Int      @id @default(autoincrement())
  ghlContactId String   // GoHighLevel contact ID
  subcategory  String   // Subcategory id, e.g. "restaurants", "hvac"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([ghlContactId, subcategory])
  @@index([ghlContactId])
  @@index([subcategory])
  @@map("member_categories")
}

// Business category definitions — single source of truth for the category tree
model BusinessCategory {
  id            String               @id // e.g. "food-beverage"
  name          String
  icon          String               // lucide-react icon name, e.g. "Utensils"
  sortOrder     Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  subcategories BusinessSubcategory[]

  @@map("business_categories")
}

model BusinessSubcategory {
  id         String           @id // e.g. "restaurants"
  name       String
  categoryId String
  sortOrder  Int              @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  category   BusinessCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("business_subcategories")
}

// Blog post categories
model PostCategory {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  slug        String   @unique
  img         String?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  posts       Post[]
  
  @@index([slug])
  @@map("post_categories")
}

// Blog post authors
model PostAuthor {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  image       String
  bio         String?  @db.Text
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  posts       Post[]
  
  @@index([slug])
  @@map("post_authors")
}

// Blog posts
model Post {
  id         String       @id @default(cuid())
  title      String
  metadata   String?      @db.Text // SEO meta description
  slug       String       @unique
  authorId   Int
  categoryId Int
  tags       String[]     // Array of tags
  mainImage  String?      // Main post image URL (optional)
  body       String       @db.Text // Rich text content (HTML)
  published  Boolean      @default(false) // Whether post is publicly visible
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  
  // Relations
  author     PostAuthor   @relation(fields: [authorId], references: [id])
  category   PostCategory @relation(fields: [categoryId], references: [id])
  galleries  Gallery[]    // Post can have multiple galleries
  
  @@index([slug])
  @@index([authorId])
  @@index([categoryId])
  @@index([createdAt])
  @@index([published])
  @@map("posts")
}

// Gallery for blog posts - each post can have multiple galleries with titles
model Gallery {
  id           String   @id @default(cuid())
  postId       String
  title        String   // Gallery title (e.g., "Event Photos", "Product Showcase")
  images       String[] // Array of image URLs
  displayOrder Int      @default(0) // Order for displaying galleries
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relations
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  @@index([postId])
  @@index([postId, displayOrder])
  @@map("galleries")
}

// Form Embeds - Securely store form embed codes
model FormEmbed {
  id                String   @id @default(cuid())
  name              String   // Display name for the form
  
  // Legacy field - kept for backward compatibility
  embedCode         String?  @db.Text // The actual embed code (iframe, script, etc.)
  
  // New fields for different membership tiers
  basicEmbedCode    String?  @db.Text
  enhancedEmbedCode String?  @db.Text
  eliteEmbedCode    String?  @db.Text
  
  // Alternative: external URL instead of embed codes
  externalUrl       String?  @db.Text
  
  createdBy         Int?     // Optional: User who created it
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([createdBy])
  @@map("form_embeds")
}
