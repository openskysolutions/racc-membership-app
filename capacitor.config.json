{
  "appId": "com.racc.membership",
  "appName": "Richfield Area Chamber of Commerce",
  "webDir": "dist",
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true
    }
  },
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "allowNavigation": ["*"]
  },
  "ios": {
    "contentInset": "never",
    "backgroundColor": "#FFFFFFFF",
    "webContentsDebuggingEnabled": true,
    "plugins": {
      "SplashScreen": {
        "launchShowDuration": 2000,
        "launchAutoHide": true,
        "launchFadeOutDuration": 1000,
        "showSpinner": false,
        "iosSpinnerStyle": "small",
        "spinnerColor": "#999999"
      }
    }
  }
}
