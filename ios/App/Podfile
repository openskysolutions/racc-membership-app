require_relative '../../node_modules/@capacitor/ios/scripts/pods_helpers'

platform :ios, '14.0'
use_frameworks!

# workaround to avoid Xcode caching of Pods that requires
# Product -> Clean Build Folder after new Cordova plugins installed
# Requires CocoaPods 1.6 or newer
install! 'cocoapods', :disable_input_output_paths => true

def capacitor_pods
  pod 'Capacitor', :path => '../../node_modules/@capacitor/ios'
  pod 'CapacitorCordova', :path => '../../node_modules/@capacitor/ios'
  pod 'CapacitorBrowser', :path => '../../node_modules/@capacitor/browser'
  pod 'CapacitorSplashScreen', :path => '../../node_modules/@capacitor/splash-screen'
  pod 'CapacitorStatusBar', :path => '../../node_modules/@capacitor/status-bar'
  pod 'CapgoCapacitorNavigationBar', :path => '../../node_modules/@capgo/capacitor-navigation-bar'
  pod 'EbarooniCapacitorCalendar', :path => '../../node_modules/@ebarooni/capacitor-calendar'
  pod 'CapacitorPluginSafeArea', :path => '../../node_modules/capacitor-plugin-safe-area'
end

target 'App' do
  capacitor_pods
  # Add your Pods here
end

post_install do |installer|
  assertDeploymentTarget(installer)
  
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
    end
  end
  
  # Fix for rsync Capacitor.framework symlink issue
  installer.pods_project.targets.each do |target|
    if target.name == 'Pods-App'
      frameworks_script_path = "Pods/Target Support Files/Pods-App/Pods-App-frameworks.sh"
      frameworks_script = File.read(frameworks_script_path)
      
      # Replace the symlink handling section to resolve relative paths
      old_symlink_code = /  if \[ -L "\$\{source\}" \]; then\n    echo "Symlinked\.\.\."\n    source="\$\(readlink "\$\{source\}"\)"\n  fi/
      
      new_symlink_code = '  if [ -L "${source}" ]; then
    echo "Symlinked..."
    # Get the directory of the symlink and resolve relative path to absolute
    local source_dir="$(dirname "${source}")"
    local link_target="$(readlink "${source}")"
    # If readlink returned a relative path, make it absolute
    case "${link_target}" in
      /*) source="${link_target}" ;;
      *) source="${source_dir}/${link_target}" ;;
    esac
    # Resolve any remaining .. or . in the path
    source="$(cd "$(dirname "${source}")" && pwd)/$(basename "${source}")"
  fi'
      
      if frameworks_script.match?(old_symlink_code)
        frameworks_script.gsub!(old_symlink_code, new_symlink_code)
        File.write(frameworks_script_path, frameworks_script)
        puts "✅ Applied symlink resolution fix to Pods-App-frameworks.sh"
      end
    end
  end
end
